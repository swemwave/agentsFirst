rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      allow create: if isOwner(userId) &&
        request.resource.data.role in ["buyer", "seller"] &&
        request.resource.data.email is string &&
        request.resource.data.fullName is string;

      allow read: if isOwner(userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /appointmentSlots/{slotId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.bookedByUid == request.auth.uid &&
        request.resource.data.dateKey is string &&
        request.resource.data.timeLabel is string &&
        request.resource.data.appointmentId == slotId;

      allow update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow create: if isSignedIn() &&
        request.resource.data.clientUid == request.auth.uid &&
        request.resource.data.slotId == appointmentId &&
        request.resource.data.dateKey is string &&
        request.resource.data.timeLabel is string &&
        request.resource.data.purpose in ["buying", "selling"] &&
        request.resource.data.status == "scheduled" &&
        request.resource.data.clientName is string &&
        request.resource.data.clientEmail is string &&
        request.resource.data.clientPhone is string &&
        request.resource.data.propertyAddress is string &&
        request.resource.data.message is string &&
        request.resource.data.agentName is string;

      allow read: if isSignedIn() &&
        (resource.data.clientUid == request.auth.uid || isAdmin());

      allow update, delete: if isAdmin();
    }
  }
}
